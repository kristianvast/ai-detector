{
    "$schema": "https://raw.githubusercontent.com/ESchouten/ai-detector/main/config/config.schema.json",
    "detectors": [
        {
            "detection": {
                "source": [
                    "sprong24.mp4"
                ]
            },
            "yolo": {
                "model": "https://github.com/CowCatcherAI/CowCatcherAI/releases/download/modelv-14/cowcatcherV15.pt",
                "confidence": 0.8,
                "time_max": 30,
                "timeout": 6,
                "frames_min": 3
            },
            "vlm": {
                "prompt": "Do you see cows that are mounting each other?",
                "key": "<your_llm_api_key>",
                "model": [
                    "gemini/gemini-3-flash-preview",
                    "gemini/gemini-2.5-flash-lite",
                    "gemini/gemini-2.5-flash"
                ]
            },
            "exporters": {
                "telegram": {
                    "token": "<your_bot_token>",
                    "chat": "<your_chat_id>"
                },
                "disk": {
                    "directory": "mounts"
                }
            }
        }
    ]
}