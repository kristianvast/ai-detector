{
  "$defs": {
    "ChatConfig": {
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "crop_padding": {
          "default": 0.1,
          "title": "Crop Padding",
          "type": "number"
        },
        "export_rejected": {
          "default": false,
          "title": "Export Rejected",
          "type": "boolean"
        },
        "token": {
          "title": "Token",
          "type": "string"
        },
        "chat": {
          "title": "Chat",
          "type": "string"
        },
        "alert_every": {
          "default": 1,
          "title": "Alert Every",
          "type": "integer"
        },
        "include_plot": {
          "default": false,
          "title": "Include Plot",
          "type": "boolean"
        },
        "include_crop": {
          "default": false,
          "title": "Include Crop",
          "type": "boolean"
        },
        "include_video": {
          "default": true,
          "title": "Include Video",
          "type": "boolean"
        },
        "video_width": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 1280,
          "title": "Video Width"
        },
        "video_crf": {
          "default": 28,
          "title": "Video Crf",
          "type": "integer"
        }
      },
      "required": [
        "token",
        "chat"
      ],
      "title": "ChatConfig",
      "type": "object"
    },
    "DetectionConfig": {
      "properties": {
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Source"
        },
        "interval": {
          "default": 0,
          "title": "Interval",
          "type": "number"
        },
        "frame_retention": {
          "default": 30,
          "title": "Frame Retention",
          "type": "integer"
        }
      },
      "required": [
        "source"
      ],
      "title": "DetectionConfig",
      "type": "object"
    },
    "DetectorConfig": {
      "properties": {
        "detection": {
          "$ref": "#/$defs/DetectionConfig"
        },
        "yolo": {
          "anyOf": [
            {
              "$ref": "#/$defs/YoloConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "vlm": {
          "anyOf": [
            {
              "$ref": "#/$defs/VLMConfig"
            },
            {
              "items": {
                "$ref": "#/$defs/VLMConfig"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vlm"
        },
        "exporters": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExportersConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "detection"
      ],
      "title": "DetectorConfig",
      "type": "object"
    },
    "DiskConfig": {
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "crop_padding": {
          "default": 0.1,
          "title": "Crop Padding",
          "type": "number"
        },
        "export_rejected": {
          "default": true,
          "title": "Export Rejected",
          "type": "boolean"
        },
        "directory": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Directory"
        },
        "strategy": {
          "default": "BEST",
          "enum": [
            "ALL",
            "BEST"
          ],
          "title": "Strategy",
          "type": "string"
        }
      },
      "title": "DiskConfig",
      "type": "object"
    },
    "ExportersConfig": {
      "properties": {
        "disk": {
          "anyOf": [
            {
              "$ref": "#/$defs/DiskConfig"
            },
            {
              "items": {
                "$ref": "#/$defs/DiskConfig"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Disk"
        },
        "telegram": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChatConfig"
            },
            {
              "items": {
                "$ref": "#/$defs/ChatConfig"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Telegram"
        },
        "webhook": {
          "anyOf": [
            {
              "$ref": "#/$defs/WebhookConfig"
            },
            {
              "items": {
                "$ref": "#/$defs/WebhookConfig"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Webhook"
        }
      },
      "title": "ExportersConfig",
      "type": "object"
    },
    "HealthcheckConfig": {
      "properties": {
        "url": {
          "title": "Url",
          "type": "string"
        },
        "method": {
          "default": "GET",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE",
            "HEAD"
          ],
          "title": "Method",
          "type": "string"
        },
        "interval": {
          "default": 60,
          "title": "Interval",
          "type": "integer"
        },
        "timeout": {
          "default": 5,
          "title": "Timeout",
          "type": "integer"
        },
        "headers": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headers"
        },
        "body": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Body"
        }
      },
      "required": [
        "url"
      ],
      "title": "HealthcheckConfig",
      "type": "object"
    },
    "OnnxConfig": {
      "properties": {
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "winml": {
          "default": true,
          "title": "Winml",
          "type": "boolean"
        },
        "opset": {
          "default": 20,
          "title": "Opset",
          "type": "integer"
        }
      },
      "title": "OnnxConfig",
      "type": "object"
    },
    "VLMConfig": {
      "properties": {
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Model"
        },
        "key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Key"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "strategy": {
          "default": "VIDEO",
          "enum": [
            "IMAGE",
            "VIDEO"
          ],
          "title": "Strategy",
          "type": "string"
        },
        "crop_padding": {
          "default": 0.1,
          "title": "Crop Padding",
          "type": "number"
        }
      },
      "required": [
        "prompt",
        "model"
      ],
      "title": "VLMConfig",
      "type": "object"
    },
    "WebhookConfig": {
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "crop_padding": {
          "default": 0.1,
          "title": "Crop Padding",
          "type": "number"
        },
        "export_rejected": {
          "default": false,
          "title": "Export Rejected",
          "type": "boolean"
        },
        "url": {
          "title": "Url",
          "type": "string"
        },
        "token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Token"
        },
        "data_type": {
          "default": "binary",
          "enum": [
            "binary",
            "base64"
          ],
          "title": "Data Type",
          "type": "string"
        },
        "data_max": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data Max"
        },
        "include_plot": {
          "default": false,
          "title": "Include Plot",
          "type": "boolean"
        },
        "include_crop": {
          "default": true,
          "title": "Include Crop",
          "type": "boolean"
        },
        "include_video": {
          "default": false,
          "title": "Include Video",
          "type": "boolean"
        },
        "video_width": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 1280,
          "title": "Video Width"
        },
        "video_crf": {
          "default": 28,
          "title": "Video Crf",
          "type": "integer"
        }
      },
      "required": [
        "url"
      ],
      "title": "WebhookConfig",
      "type": "object"
    },
    "YoloConfig": {
      "properties": {
        "model": {
          "title": "Model",
          "type": "string"
        },
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            }
          ],
          "default": 0,
          "title": "Confidence"
        },
        "time_max": {
          "default": 60,
          "title": "Time Max",
          "type": "integer"
        },
        "timeout": {
          "default": 5,
          "title": "Timeout",
          "type": "integer"
        },
        "cooldown": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            }
          ],
          "default": 0,
          "title": "Cooldown"
        },
        "include_trailing_time": {
          "default": 1,
          "title": "Include Trailing Time",
          "type": "integer"
        },
        "frames_min": {
          "title": "Frames Min",
          "type": "integer"
        },
        "imgsz": {
          "default": 640,
          "title": "Imgsz",
          "type": "integer"
        },
        "strategy": {
          "default": "LATEST",
          "enum": [
            "LATEST",
            "ALL"
          ],
          "title": "Strategy",
          "type": "string"
        }
      },
      "required": [
        "model"
      ],
      "title": "YoloConfig",
      "type": "object"
    }
  },
  "properties": {
    "detectors": {
      "items": {
        "$ref": "#/$defs/DetectorConfig"
      },
      "title": "Detectors",
      "type": "array"
    },
    "onnx": {
      "$ref": "#/$defs/OnnxConfig"
    },
    "health": {
      "anyOf": [
        {
          "$ref": "#/$defs/HealthcheckConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "detectors"
  ],
  "title": "Config",
  "type": "object"
}